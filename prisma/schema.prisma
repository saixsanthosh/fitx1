// FITX — Prisma schema (PostgreSQL)
// Run: npx prisma migrate dev   |   npx prisma db seed

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String         @id @default(cuid())
  email        String         @unique
  name         String
  passwordHash String
  avatar       String?
  level        Int            @default(1)
  xp           Int            @default(0)
  streak       Int            @default(0)
  bestStreak   Int            @default(0)
  experience   String         @default("Beginner")
  dietMode     String         @default("Maintenance")
  workoutMode  String         @default("Gym")
  gender       String?
  age          Int?
  height       Float?
  weight       Float?
  targetWeight Float?
  goals        String[]
  plan         String         @default("Free")
  gymId        String?
  gym          Gym?           @relation(fields: [gymId], references: [id])
  workouts     WorkoutSession[]
  meals        MealEntry[]
  tasks        Task[]
  habits       Habit[]
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
}

model Exercise {
  id               String   @id @default(cuid())
  name             String
  muscleGroup      String
  secondaryMuscles String[]
  equipment        String[]
  difficulty       String
  type             String
  forceType        String
  instructions     String[]
  tips             String[]
  commonMistakes   String[]
  videoUrl         String?
  gifUrl           String?
  thumbnailUrl     String?
  alternatives     String[]
  musclesWorked    String[]
}

model Program {
  id          String   @id @default(cuid())
  name        String
  weeks       Int
  level       String
  rating      Float    @default(0)
  enrolled    Int      @default(0)
  coach       String?
  description String?
}

model WorkoutSession {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  date          DateTime @default(now())
  duration      Int
  totalVolume   Float    @default(0)
  caloriesBurned Int     @default(0)
  prs           Int      @default(0)
  exercises     Json
}

model MealEntry {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  date        DateTime @default(now())
  meal        String
  foodName    String
  calories    Int
  protein     Float
  carbs       Float
  fat         Float
  servingSize String?
}

model Task {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id])
  title           String
  description     String?
  category        String
  priority        String    @default("Medium")
  status          String    @default("pending")
  dueDate         DateTime?
  dueTime         String?
  recurring       String    @default("None")
  linkedWorkoutId String?
  tags            String[]
  createdAt       DateTime  @default(now())
}

model Habit {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  name          String
  category      String
  frequency     String   @default("Daily")
  currentStreak Int      @default(0)
  bestStreak    Int      @default(0)
  completionLog Json     @default("{}")
}

model Gym {
  id           String  @id @default(cuid())
  name         String
  logoUrl      String?
  primaryColor String  @default("#E8160C")
  accentColor  String  @default("#D4A040")
  members      User[]
  createdAt    DateTime @default(now())
}
